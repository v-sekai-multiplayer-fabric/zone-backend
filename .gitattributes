# Shell scripts and the NIF compiler wrappers must stay LF so they run on
# Linux/macOS regardless of the committer's platform.
*.sh text eol=lf
scripts/nif-compile text eol=lf
scripts/zig-cc text eol=lf
scripts/zig-cxx text eol=lf

# Elixir sources must stay LF so `mix format --check-formatted` passes on
# Linux CI regardless of the committer's platform.
*.ex text eol=lf
*.exs text eol=lf
