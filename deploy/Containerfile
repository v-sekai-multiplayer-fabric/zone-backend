# syntax=docker/dockerfile:1
# Multi-stage build for the hosted taskweft MCP server.
# Stage 1 compiles the C++ NIF + an Elixir prod release (which excludes
# test-only deps like timex/tzdata/hackney/cowlib). Stage 2 is a slim runtime.
#
# Build context is the taskweft monorepo ROOT (not deploy/) — taskweft_deploy
# depends on taskweft via a path dep ({:taskweft, path: ".."}), so both the
# parent app's source and deploy/'s own source need to be present at their
# real relative on-disk layout for Mix to resolve it.

ARG ELIXIR_IMAGE=docker.io/hexpm/elixir:1.17.3-erlang-27.2-debian-bookworm-20241202-slim
ARG RUNTIME_IMAGE=docker.io/debian:bookworm-slim

# ---------- build ----------
FROM ${ELIXIR_IMAGE} AS build

# build-essential/g++ for the taskweft_nif C++20 NIF; git for github: deps; curl for rebar3.
RUN apt-get update -y \
  && apt-get install -y --no-install-recommends build-essential git ca-certificates make curl \
  && rm -rf /var/lib/apt/lists/*

ENV MIX_ENV=prod

# Install hex + rebar3 WITHOUT hitting builds.hex.pm — OTP 27 rejects its cert
# chain with a key_usage_mismatch TLS alert (repo.hex.pm and GitHub are fine).
# hex comes from its git repo; rebar3 from its GitHub release.
RUN mix archive.install github hexpm/hex branch latest --force
RUN curl -fsSL -o /usr/local/bin/rebar3 https://github.com/erlang/rebar3/releases/latest/download/rebar3 \
  && chmod +x /usr/local/bin/rebar3 \
  && mix local.rebar rebar3 /usr/local/bin/rebar3 --force

# taskweft (the path-dep parent) — mix.exs + lib, and priv (some modules
# embed bundled static data at compile time via @external_resource +
# File.read!, e.g. lib/taskweft/jsonld/loader.ex's JSON Schema — that read
# happens during `mix compile` below, so priv/ must exist in this build
# stage even though the resulting release doesn't need its own runtime copy
# of that specific file, since the content is baked into the .beam).
# Mix resolves the path dep's own deps from its mix.exs, not a separate lock.
WORKDIR /app
COPY mix.exs ./
COPY lib lib
COPY priv priv

WORKDIR /app/deploy
COPY deploy/mix.exs deploy/mix.lock* ./
RUN mix deps.get --only prod
RUN mix deps.compile

# Baked in at compile time (not read from a runtime env var) so /health's
# git_sha can never drift from what was actually compiled into this image —
# no separate "did I remember to pass this to the container too" step.
ARG GIT_SHA=unknown
ENV GIT_SHA=${GIT_SHA}

COPY deploy/config config
COPY deploy/lib lib
RUN mix compile
RUN mix release

# ---------- runtime ----------
FROM ${RUNTIME_IMAGE} AS app

RUN apt-get update -y \
  && apt-get install -y --no-install-recommends libstdc++6 openssl libncurses6 ca-certificates \
  && rm -rf /var/lib/apt/lists/*

ENV MIX_ENV=prod \
    PORT=8080 \
    LANG=C.UTF-8

WORKDIR /app
COPY --from=build /app/deploy/_build/prod/rel/taskweft_deploy ./

# Non-root
RUN useradd --create-home app && chown -R app:app /app
USER app

EXPOSE 8080
CMD ["/app/bin/taskweft_deploy", "start"]
