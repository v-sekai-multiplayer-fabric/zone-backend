{
  "@context": {
    "khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/",
    "domain": "khr:planning/domain/"
  },
  "@type": "domain:Definition",
  "name": "entity_capabilities",
  "version": "1.0",
  "description": "Multi-agent movement domain with heterogeneous entity capabilities. Each entity type can only execute the action matching its capability (fly / swim / walk). The planner filters alternatives via the capabilities section: domain.actions lists required capabilities per action; domain.capabilities.entities lists the capabilities each entity holds. Only alternatives whose required capability is held by the agent are tried. Implements IPyHOP-temporal ReBAC capability filtering (HAS_CAPABILITY relationships). Demonstrates RECTGTN 'E' with action-capability guards.",
  "enums": {
    "location": {
      "base": 0,
      "mountain": 1,
      "harbor": 2,
      "offshore": 3,
      "city": 4,
      "shore": 5,
      "island": 6
    }
  },
  "variables": [
    {
      "name": "loc",
      "type": "int",
      "description": "Current location of each entity. Int keys correspond to location enum values.",
      "init": {
        "drone_1": 0,
        "drone_2": 0,
        "boat_1": 2,
        "boat_2": 2,
        "human_1": 0,
        "human_2": 0,
        "amphibious_1": 5
      }
    }
  ],
  "capabilities": {
    "entities": {
      "drone_1": [
        "fly"
      ],
      "drone_2": [
        "fly"
      ],
      "boat_1": [
        "swim"
      ],
      "boat_2": [
        "swim"
      ],
      "human_1": [
        "walk"
      ],
      "human_2": [
        "walk"
      ],
      "amphibious_1": [
        "swim",
        "walk"
      ]
    }
  },
  "actions": {
    "a_fly": {
      "description": "Aerial movement. Requires fly capability. Fast — no terrain restrictions.",
      "duration": "PT5M",
      "params": [
        "agent",
        "to_loc"
      ],
      "body": [
        {
          "eval": {
            "type": "rebac/check",
            "rel": "HAS_CAPABILITY",
            "subject": "{agent}",
            "object": "fly"
          }
        },
        {
          "pointer/set": "/loc/{agent}",
          "value": "{to_loc}"
        }
      ]
    },
    "a_swim": {
      "description": "Aquatic movement. Requires swim capability.",
      "duration": "PT20M",
      "params": [
        "agent",
        "to_loc"
      ],
      "body": [
        {
          "eval": {
            "type": "rebac/check",
            "rel": "HAS_CAPABILITY",
            "subject": "{agent}",
            "object": "swim"
          }
        },
        {
          "pointer/set": "/loc/{agent}",
          "value": "{to_loc}"
        }
      ]
    },
    "a_walk": {
      "description": "Ground movement. Requires walk capability. Slowest mode.",
      "duration": "PT30M",
      "params": [
        "agent",
        "to_loc"
      ],
      "body": [
        {
          "eval": {
            "type": "rebac/check",
            "rel": "HAS_CAPABILITY",
            "subject": "{agent}",
            "object": "walk"
          }
        },
        {
          "pointer/set": "/loc/{agent}",
          "value": "{to_loc}"
        }
      ]
    }
  },
  "methods": {
    "m_move": {
      "description": "Move an agent to a target location using any capability it holds. The planner tries alternatives in order; the capabilities filter prunes those requiring capabilities the agent lacks.",
      "params": [
        "agent",
        "to_loc"
      ],
      "alternatives": [
        {
          "name": "fly",
          "subtasks": [
            [
              "a_fly",
              "{agent}",
              "{to_loc}"
            ]
          ]
        },
        {
          "name": "swim",
          "subtasks": [
            [
              "a_swim",
              "{agent}",
              "{to_loc}"
            ]
          ]
        },
        {
          "name": "walk",
          "subtasks": [
            [
              "a_walk",
              "{agent}",
              "{to_loc}"
            ]
          ]
        }
      ]
    },
    "loc": {
      "description": "Goal method: move entity to desired location using m_move.",
      "params": [
        "agent",
        "dest"
      ],
      "alternatives": [
        {
          "name": "move_to_dest",
          "subtasks": [
            [
              "m_move",
              "{agent}",
              "{dest}"
            ]
          ]
        }
      ]
    }
  },
  "todo_list": [
    [
      "m_move",
      "drone_1",
      1
    ]
  ]
}
