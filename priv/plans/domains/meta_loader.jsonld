{
  "@context": {
    "khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/",
    "domain": "khr:planning/domain/"
  },
  "@type": "domain:MetaDomain",
  "name": "meta_loader",
  "description": "The domain loader expressed as a domain. Homoiconic: the loader uses the same bind/check/set vocabulary it interprets. Each action below corresponds to a loader operation on the planner registry. This meta-domain demonstrates homoiconicity: the loader that interprets bind/check/set is itself described using bind/check/set. The three primitives (exec_bind = variable/get, exec_check = variable/get + math/ieq + flow/branch, exec_set = variable/set) are the complete standard library for state manipulation in KHR_interactivity.",
  "actions": {
    "resolve_val": {
      "description": "Resolve a {param} template as a value through enum lookup. Maps to variable/get + math/select.",
      "params": [
        "template",
        "bindings",
        "enums"
      ],
      "body": [
        {
          "bind": [
            {
              "name": "raw",
              "from": [
                "bindings",
                "{template}"
              ]
            }
          ]
        },
        {
          "pointer/set": [
            "result",
            "val"
          ],
          "value": "{raw}"
        }
      ]
    },
    "resolve_key": {
      "description": "Resolve a {param} template as a dict key (no enum). Maps to variable/get.",
      "params": [
        "template",
        "bindings"
      ],
      "body": [
        {
          "bind": [
            {
              "name": "raw",
              "from": [
                "bindings",
                "{template}"
              ]
            }
          ]
        },
        {
          "pointer/set": [
            "result",
            "key"
          ],
          "value": "{raw}"
        }
      ]
    },
    "exec_bind": {
      "description": "variable/get: read state[var][key] and store in bindings[name].",
      "params": [
        "var",
        "key",
        "name"
      ],
      "body": [
        {
          "bind": [
            {
              "name": "val",
              "from": [
                "{var}",
                "{key}"
              ]
            }
          ]
        },
        {
          "pointer/set": [
            "bindings",
            "{name}"
          ],
          "value": "{val}"
        }
      ]
    },
    "exec_check": {
      "description": "variable/get + math/ieq: read state[var][key], compare to expected. Fail (return None) on mismatch. Maps to flow/branch(false → fail).",
      "params": [
        "var",
        "key",
        "expected"
      ],
      "body": [
        {
          "check": [
            "{var}",
            "{key}"
          ],
          "eq": "{expected}"
        }
      ]
    },
    "exec_set": {
      "description": "variable/set: write state[var][key] = value.",
      "params": [
        "var",
        "key",
        "value"
      ],
      "body": [
        {
          "pointer/set": [
            "{var}",
            "{key}"
          ],
          "value": "{value}"
        }
      ]
    },
    "register_action": {
      "description": "Create an IPyHOP action from a sequence of bind/check/set steps. The action body is data — each step is one of the three primitives above.",
      "params": [
        "name",
        "params",
        "bind_steps",
        "body_steps",
        "enums"
      ],
      "body": []
    },
    "register_method": {
      "description": "Create an IPyHOP task method from alternatives. Each alternative is a sequence of bind/check steps followed by a subtask list.",
      "params": [
        "task_name",
        "params",
        "alternatives"
      ],
      "body": []
    },
    "register_goal_method": {
      "description": "Create an IPyHOP goal method. Same as register_method but registered via declare_goal_methods for unigoal verification (RECTGTN C).",
      "params": [
        "goal_name",
        "params",
        "alternatives"
      ],
      "body": []
    },
    "register_multigoal_method": {
      "description": "Create an IPyHOP multigoal method. Decomposes a conjunction of unigoals one at a time (RECTGTN N).",
      "params": [
        "tag"
      ],
      "body": []
    },
    "register_capabilities": {
      "description": "Wire entity capabilities into IPyHOP's built-in filtering system.",
      "params": [
        "entity_caps",
        "action_caps"
      ],
      "body": []
    },
    "init_state": {
      "description": "Create IPyHOP State from variable definitions.",
      "params": [
        "name",
        "variables"
      ],
      "body": []
    }
  },
  "methods": {
    "load_domain": {
      "description": "Top-level: load a JSON-LD domain definition into IPyHOP RECTGTN elements.",
      "params": [
        "domain_def"
      ],
      "alternatives": [
        {
          "name": "standard",
          "subtasks": [
            [
              "init_state",
              "{name}",
              "{variables}"
            ],
            [
              "register_all_actions",
              "{actions}",
              "{enums}"
            ],
            [
              "register_all_methods",
              "{methods}",
              "{enums}"
            ],
            [
              "register_all_goals",
              "{goals}",
              "{enums}"
            ],
            [
              "register_all_multigoals",
              "{multigoals}"
            ],
            [
              "register_capabilities",
              "{capabilities.entities}",
              "{capabilities.actions}"
            ]
          ]
        }
      ]
    }
  }
}
