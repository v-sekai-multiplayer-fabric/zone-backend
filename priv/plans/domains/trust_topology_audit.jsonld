{
  "@context": {
    "khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/",
    "domain": "khr:planning/domain/"
  },
  "@type": "domain:Definition",
  "name": "trust_topology_audit",
  "description": "Audit a project's verification pipeline using Michael Rothrock's Trust Topology framework (https://michael.roth.rocks/research/trust-topology). The framework treats reliability as a property of the gate arrangement, not of any single model or check inside it, and provides four diagnostic properties: overlap ratio, verification amplification, deterministic ceiling, and the liveness constraint. This domain plans the sequence of writing such an audit: enumerate the existing gates, apply each of the four properties as a separate analytical pass, synthesize recommendations, and publish the result.",
  "variables": [
    {
      "name": "sections_drafted",
      "type": "bool",
      "init": {
        "gate_inventory": false,
        "overlap_ratio": false,
        "verification_amplification": false,
        "deterministic_ceiling": false,
        "liveness_constraint": false,
        "synthesis_recommendations": false
      }
    },
    {
      "name": "audit_published",
      "type": "bool",
      "init": {
        "doc_committed": false
      }
    }
  ],
  "actions": {
    "a_inventory_gates": {
      "params": [],
      "body": [
        {
          "pointer/set": "/sections_drafted/gate_inventory",
          "value": true
        }
      ]
    },
    "a_apply_overlap_ratio": {
      "params": [],
      "body": [
        {
          "eval": {
            "type": "math/eq",
            "a": {
              "type": "pointer/get",
              "pointer": "/sections_drafted/gate_inventory"
            },
            "b": true
          }
        },
        {
          "pointer/set": "/sections_drafted/overlap_ratio",
          "value": true
        }
      ]
    },
    "a_apply_verification_amplification": {
      "params": [],
      "body": [
        {
          "eval": {
            "type": "math/eq",
            "a": {
              "type": "pointer/get",
              "pointer": "/sections_drafted/gate_inventory"
            },
            "b": true
          }
        },
        {
          "pointer/set": "/sections_drafted/verification_amplification",
          "value": true
        }
      ]
    },
    "a_apply_deterministic_ceiling": {
      "params": [],
      "body": [
        {
          "eval": {
            "type": "math/eq",
            "a": {
              "type": "pointer/get",
              "pointer": "/sections_drafted/gate_inventory"
            },
            "b": true
          }
        },
        {
          "pointer/set": "/sections_drafted/deterministic_ceiling",
          "value": true
        }
      ]
    },
    "a_apply_liveness_constraint": {
      "params": [],
      "body": [
        {
          "eval": {
            "type": "math/eq",
            "a": {
              "type": "pointer/get",
              "pointer": "/sections_drafted/gate_inventory"
            },
            "b": true
          }
        },
        {
          "pointer/set": "/sections_drafted/liveness_constraint",
          "value": true
        }
      ]
    },
    "a_synthesize_recommendations": {
      "params": [],
      "body": [
        {
          "eval": {
            "type": "math/eq",
            "a": {
              "type": "pointer/get",
              "pointer": "/sections_drafted/overlap_ratio"
            },
            "b": true
          }
        },
        {
          "eval": {
            "type": "math/eq",
            "a": {
              "type": "pointer/get",
              "pointer": "/sections_drafted/verification_amplification"
            },
            "b": true
          }
        },
        {
          "eval": {
            "type": "math/eq",
            "a": {
              "type": "pointer/get",
              "pointer": "/sections_drafted/deterministic_ceiling"
            },
            "b": true
          }
        },
        {
          "eval": {
            "type": "math/eq",
            "a": {
              "type": "pointer/get",
              "pointer": "/sections_drafted/liveness_constraint"
            },
            "b": true
          }
        },
        {
          "pointer/set": "/sections_drafted/synthesis_recommendations",
          "value": true
        }
      ]
    },
    "a_publish_audit": {
      "params": [],
      "body": [
        {
          "eval": {
            "type": "math/eq",
            "a": {
              "type": "pointer/get",
              "pointer": "/sections_drafted/synthesis_recommendations"
            },
            "b": true
          }
        },
        {
          "pointer/set": "/audit_published/doc_committed",
          "value": true
        }
      ]
    }
  },
  "methods": {
    "write_trust_topology_audit": {
      "params": [],
      "alternatives": [
        {
          "name": "inventory_then_four_properties_then_synth_then_publish",
          "subtasks": [
            [
              "a_inventory_gates"
            ],
            [
              "a_apply_overlap_ratio"
            ],
            [
              "a_apply_verification_amplification"
            ],
            [
              "a_apply_deterministic_ceiling"
            ],
            [
              "a_apply_liveness_constraint"
            ],
            [
              "a_synthesize_recommendations"
            ],
            [
              "a_publish_audit"
            ]
          ]
        }
      ]
    }
  },
  "todo_list": [
    [
      "write_trust_topology_audit"
    ]
  ]
}
