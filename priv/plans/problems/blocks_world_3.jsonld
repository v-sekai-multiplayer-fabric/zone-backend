{
  "@context": {
    "khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/",
    "domain": "khr:planning/domain/"
  },
  "@type": "domain:Problem",
  "name": "blocks_world_3",
  "source": "blocks_world",
  "description": "IPyHOP blocks_world problem 3: 19 blocks, large rearrangement via scan.",
  "variables": [
    {
      "name": "pos",
      "type": "ref",
      "init": {
        "1": "12",
        "12": "13",
        "13": "table",
        "11": "10",
        "10": "5",
        "5": "4",
        "4": "14",
        "14": "15",
        "15": "table",
        "9": "8",
        "8": "7",
        "7": "6",
        "6": "table",
        "19": "18",
        "18": "17",
        "17": "16",
        "16": "3",
        "3": "2",
        "2": "table"
      }
    },
    {
      "name": "clear",
      "type": "bool",
      "init": {
        "1": true,
        "2": false,
        "3": false,
        "4": false,
        "5": false,
        "6": false,
        "7": false,
        "8": false,
        "9": true,
        "10": false,
        "11": true,
        "12": false,
        "13": false,
        "14": false,
        "15": false,
        "16": false,
        "17": false,
        "18": false,
        "19": true
      }
    },
    {
      "name": "holding",
      "type": "bool",
      "init": {
        "hand": false
      }
    },
    {
      "name": "goal_pos",
      "type": "ref",
      "init": {
        "1": "table",
        "2": "3",
        "3": "16",
        "4": "table",
        "5": "table",
        "6": "table",
        "7": "6",
        "8": "9",
        "9": "4",
        "10": "table",
        "11": "7",
        "12": "2",
        "13": "8",
        "14": "table",
        "15": "13",
        "16": "11",
        "17": "table",
        "18": "table",
        "19": "table"
      }
    }
  ],
  "methods": {
    "move_blocks": {
      "params": [],
      "name": "move_blocks",
      "scan": {
        "over": "clear",
        "recurse": "move_blocks",
        "branches": [
          {
            "name": "move_to_block",
            "bind": [
              {
                "name": "gk",
                "pointer": "/goal_pos/{_key}"
              },
              {
                "name": "ggk",
                "pointer": "/goal_pos/{gk}"
              }
            ],
            "check": [
              {
                "pointer": "/clear/{_key}",
                "eq": true
              },
              {
                "pointer": "/pos/{_key}",
                "neq": "{gk}"
              },
              {
                "pointer": "/goal_pos/{_key}",
                "neq": "table"
              },
              {
                "pointer": "/pos/{gk}",
                "eq": "{ggk}"
              },
              {
                "pointer": "/clear/{gk}",
                "eq": true
              }
            ],
            "subtasks": [
              [
                "move_one",
                "{_key}",
                "{gk}"
              ]
            ]
          },
          {
            "name": "move_to_table",
            "check": [
              {
                "pointer": "/clear/{_key}",
                "eq": true
              },
              {
                "pointer": "/goal_pos/{_key}",
                "eq": "table"
              },
              {
                "pointer": "/pos/{_key}",
                "neq": "table"
              }
            ],
            "subtasks": [
              [
                "move_one",
                "{_key}",
                "table"
              ]
            ]
          },
          {
            "name": "waiting",
            "bind": [
              {
                "name": "gk",
                "pointer": "/goal_pos/{_key}"
              }
            ],
            "check": [
              {
                "pointer": "/clear/{_key}",
                "eq": true
              },
              {
                "pointer": "/pos/{_key}",
                "neq": "{gk}"
              }
            ],
            "subtasks": [
              [
                "move_one",
                "{_key}",
                "table"
              ]
            ]
          }
        ]
      }
    }
  },
  "todo_list": [
    [
      "move_blocks"
    ]
  ]
}
