{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://taskweft.dev/schemas/rectgtn_domain.schema.json",
  "title": "RECTGTN planning domain / problem",
  "description": "JSON-LD shape a taskweft domain or problem document may take. See docs/rectgtn.md for the prose description this mirrors. This is the sole structural/shape validation Taskweft.JSONLD.Loader enforces — cross-referencing checks a document-shape schema can't express (call arity, {param} references, ISO 8601 duration grammar) still run separately in Elixir. A goal is state (variables) plus an ordinary task call reaching it — ['method_name', ...args].",
  "type": "object",
  "required": ["@type", "name"],
  "properties": {
    "@context": {
      "description": "Inline map, local/remote reference (string), or array of either — resolved by Taskweft.JSONLD.Loader before this schema ever sees the document, so no further shape is enforced here."
    },
    "@type": {
      "enum": [
        "domain:Definition",
        "domain:MetaDomain",
        "domain:Problem"
      ]
    },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "version": { "type": "string" },
    "source": {
      "type": "string",
      "description": "Problem documents may name their paired domain's stem here (e.g. \"blocks_world\")."
    },
    "enums": {
      "type": "object",
      "additionalProperties": { "type": "object" }
    },
    "variables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "init": {
            "description": "Optional: a domain may declare a variable with no init at all, relying entirely on a paired problem's own variables entry to supply it at merge time (e.g. service_bringup.jsonld's per-item phase/approach state — \"key space supplied by the problem\")."
          }
        }
      }
    },
    "actions": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/action" }
    },
    "methods": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/method" }
    },
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/task" }
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "entities": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "actions": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "#/$defs/capability_requirement" }
          }
        },
        "graph": { "$ref": "#/$defs/rebac_graph" }
      }
    }
  },
  "$defs": {
    "action": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "duration": {
          "type": "string",
          "description": "ISO 8601 duration (e.g. \"PT5M\"); grammar enforced by Taskweft.Iso8601Duration, not this schema."
        },
        "params": {
          "type": "array",
          "items": { "type": "string" }
        },
        "bind": {
          "type": "array",
          "items": { "type": "object" }
        },
        "body": {
          "type": "array",
          "items": { "$ref": "#/$defs/body_step" }
        }
      }
    },
    "body_step": {
      "type": "object",
      "oneOf": [
        { "required": ["eval"] },
        { "required": ["pointer/set", "value"] }
      ]
    },
    "method": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "params": {
          "type": "array",
          "items": { "type": "string" }
        },
        "scan": { "type": "object" },
        "alternatives": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["subtasks"],
            "properties": {
              "name": { "type": "string" },
              "check": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["eval"]
                }
              },
              "subtasks": {
                "type": "array",
                "items": { "type": "array" }
              }
            }
          }
        }
      }
    },
    "task": {
      "oneOf": [
        {
          "type": "array",
          "minItems": 1,
          "items": {},
          "prefixItems": [{ "type": "string" }]
        },
        {
          "type": "object",
          "required": ["multigoal"],
          "properties": {
            "multigoal": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "type": "object",
                "minProperties": 1
              }
            }
          }
        }
      ]
    },
    "capability_requirement": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["rel", "object"],
          "properties": {
            "rel": { "type": "object" },
            "object": { "type": "string" }
          }
        }
      ]
    },
    "rebac_graph": {
      "type": "object",
      "properties": {
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["subject", "object", "rel"],
            "properties": {
              "subject": { "type": "string" },
              "object": { "type": "string" },
              "rel": { "type": "string" }
            }
          }
        },
        "definitions": { "type": "object" }
      }
    }
  }
}
