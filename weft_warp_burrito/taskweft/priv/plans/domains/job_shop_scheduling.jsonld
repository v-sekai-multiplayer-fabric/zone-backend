{
  "@context": {
    "khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/",
    "domain": "khr:planning/domain/"
  },
  "@type": "domain:Definition",
  "name": "job_shop_scheduling",
  "enums": {
    "task_status": {
      "pending": 0,
      "running": 1,
      "done": 2
    }
  },
  "variables": [
    {
      "name": "task_status",
      "type": "int",
      "init": {
        "job1_taskA": 0,
        "job1_taskB": 0,
        "job2_taskC": 0,
        "job2_taskD": 0
      }
    },
    {
      "name": "machine_avail",
      "type": "int",
      "init": {
        "machine1": 1,
        "machine2": 1
      }
    }
  ],
  "actions": {
    "a_start_task": {
      "params": [
        "job_task",
        "machine"
      ],
      "body": [
        {
          "eval": {
            "type": "math/eq",
            "a": {
              "type": "pointer/get",
              "pointer": "/task_status/{job_task}"
            },
            "b": 0
          }
        },
        {
          "eval": {
            "type": "math/eq",
            "a": {
              "type": "pointer/get",
              "pointer": "/machine_avail/{machine}"
            },
            "b": 1
          }
        },
        {
          "pointer/set": "/task_status/{job_task}",
          "value": 1
        },
        {
          "pointer/set": "/machine_avail/{machine}",
          "value": 0
        }
      ]
    },
    "a_finish_task": {
      "params": [
        "job_task",
        "machine"
      ],
      "body": [
        {
          "eval": {
            "type": "math/eq",
            "a": {
              "type": "pointer/get",
              "pointer": "/task_status/{job_task}"
            },
            "b": 1
          }
        },
        {
          "pointer/set": "/task_status/{job_task}",
          "value": 2
        },
        {
          "pointer/set": "/machine_avail/{machine}",
          "value": 1
        }
      ]
    }
  },
  "methods": {
    "schedule_task": {
      "params": [
        "job_task",
        "machine"
      ],
      "alternatives": [
        {
          "name": "already_done",
          "check": [
            {
              "eval": {
                "type": "math/eq",
                "a": {
                  "type": "pointer/get",
                  "pointer": "/task_status/{job_task}"
                },
                "b": 2
              }
            }
          ],
          "subtasks": []
        },
        {
          "name": "start_and_finish",
          "subtasks": [
            [
              "a_start_task",
              "{job_task}",
              "{machine}"
            ],
            [
              "a_finish_task",
              "{job_task}",
              "{machine}"
            ]
          ]
        }
      ]
    }
  },
  "todo_list": [
    [
      "schedule_task",
      "job1_taskA",
      "machine1"
    ],
    [
      "schedule_task",
      "job1_taskB",
      "machine2"
    ],
    [
      "schedule_task",
      "job2_taskC",
      "machine2"
    ],
    [
      "schedule_task",
      "job2_taskD",
      "machine1"
    ]
  ]
}
