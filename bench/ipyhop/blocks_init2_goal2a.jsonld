{
  "@context": {"vsekai": "https://v-sekai.org/", "domain": "vsekai:planning/domain/"},
  "@type": "domain:Definition",
  "name": "ipyhop_blocks_init2_goal2a",
  "description": "IPyHOP canonical blocks_world init_state_2 + goal2a: 4 blocks, achieve b-on-c, a-on-d. Expected plan: unstack-a, putdown-a, unstack-b, stack-b-c, pickup-a, stack-a-d.",
  "variables": [
    {"name": "pos",     "init": {"a": "c", "b": "d", "c": "table", "d": "table"}},
    {"name": "clear",   "init": {"a": true, "b": true, "c": false, "d": false}},
    {"name": "holding", "init": {"hand": false}}
  ],
  "actions": {
    "a_pickup":  {"params": ["block"],          "body": [{"check": "/pos/{block}", "eq": "table"}, {"check": "/clear/{block}", "eq": true}, {"check": "/holding/hand", "eq": false}, {"set": "/pos/{block}", "value": "hand"}, {"set": "/clear/{block}", "value": false}, {"set": "/holding/hand", "value": "{block}"}]},
    "a_unstack": {"params": ["block", "under"], "body": [{"check": "/clear/{block}", "eq": true},  {"check": "/holding/hand", "eq": false}, {"set": "/pos/{block}", "value": "hand"},  {"set": "/clear/{block}", "value": false}, {"set": "/holding/hand", "value": "{block}"}, {"set": "/clear/{under}", "value": true}]},
    "a_putdown": {"params": ["block"],          "body": [{"check": "/pos/{block}", "eq": "hand"},  {"set": "/pos/{block}", "value": "table"}, {"set": "/clear/{block}", "value": true}, {"set": "/holding/hand", "value": false}]},
    "a_stack":   {"params": ["block", "target"],"body": [{"check": "/pos/{block}", "eq": "hand"},  {"check": "/clear/{target}", "eq": true},  {"set": "/pos/{block}", "value": "{target}"}, {"set": "/clear/{block}", "value": true}, {"set": "/holding/hand", "value": false}, {"set": "/clear/{target}", "value": false}]}
  },
  "methods": {
    "move_one": {"params": ["block", "dest"], "alternatives": [{"name": "get_and_put", "subtasks": [["get", "{block}"], ["put", "{block}", "{dest}"]]}]},
    "get": {
      "params": ["block"],
      "alternatives": [
        {"name": "pickup_from_table", "check": [{"pointer": "/pos/{block}", "eq": "table"}], "subtasks": [["a_pickup", "{block}"]]},
        {"name": "unstack",           "subtasks": [["a_unstack", "{block}", "/pos/{block}"]]}
      ]
    },
    "put": {
      "params": ["block", "dest"],
      "alternatives": [
        {"name": "stack_on_block",  "check": [{"pointer": "/holding/hand", "eq": "{block}"}, {"pointer": "/clear/{dest}", "eq": true}], "subtasks": [["a_stack", "{block}", "{dest}"]]},
        {"name": "putdown_on_table","check": [{"pointer": "/holding/hand", "eq": "{block}"}], "subtasks": [["a_putdown", "{block}"]]}
      ]
    }
  },
  "todo_list": [["move_one", "a", "table"], ["move_one", "b", "c"], ["move_one", "a", "d"]]
}
