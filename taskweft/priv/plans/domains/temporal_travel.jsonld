{
  "@context": {
    "khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/",
    "domain": "khr:planning/domain/"
  },
  "@type": "domain:Definition",
  "name": "temporal_travel",
  "version": "1.0",
  "description": "Travel planning domain with temporal action durations (ISO 8601). Agents can walk directly or use a taxi: call, ride, then pay. Demonstrates multi-step sequential task decomposition (RECTGTN 'T') and temporal metadata — each action carries a 'duration' field usable by a Simple Temporal Network (STN) to check schedule feasibility. Duration values follow ISO 8601 (PT = period-time prefix: PTxH = hours, PTxM = minutes).",
  "enums": {
    "location": {
      "home_a": 0,
      "home_b": 1,
      "park": 2,
      "station": 3,
      "downtown": 4
    }
  },
  "variables": [
    {
      "name": "loc",
      "type": "int",
      "description": "Current location of each agent and taxi. -1 means in transit (taxi called, not yet arrived).",
      "init": {
        "alice": 0,
        "bob": 1,
        "taxi1": 2,
        "taxi2": 3
      }
    },
    {
      "name": "cash",
      "type": "float",
      "description": "Cash on hand per agent (float, currency units).",
      "init": {
        "alice": 20.0,
        "bob": 15.0
      }
    },
    {
      "name": "owe",
      "type": "float",
      "description": "Amount owed to taxi driver per agent (accumulated during ride).",
      "init": {
        "alice": 0.0,
        "bob": 0.0
      }
    }
  ],
  "actions": {
    "a_walk": {
      "description": "Walk directly to destination. No cost, but takes longer than taxi.",
      "duration": "PT10M",
      "params": [
        "person",
        "to_loc"
      ],
      "body": [
        {
          "pointer/set": "/loc/{person}",
          "value": "{to_loc}"
        }
      ]
    },
    "a_call_taxi": {
      "description": "Hail taxi1 to current location; person enters transit state (loc = -1).",
      "duration": "PT2M",
      "params": [
        "person"
      ],
      "bind": [
        {
          "name": "here",
          "pointer": "/loc/{person}"
        }
      ],
      "body": [
        {
          "pointer/set": "/loc/taxi1",
          "value": "{here}"
        },
        {
          "pointer/set": "/loc/{person}",
          "value": -1
        }
      ]
    },
    "a_ride_taxi": {
      "description": "Ride taxi1 to destination. Person must be in transit (loc == -1). Fare = 1.5 + 0.5 * 8 (fixed route cost).",
      "duration": "PT15M",
      "params": [
        "person",
        "to_loc"
      ],
      "body": [
        {
          "eval": {
            "type": "math/eq",
            "a": {
              "type": "pointer/get",
              "pointer": "/loc/{person}"
            },
            "b": -1
          }
        },
        {
          "pointer/set": "/loc/taxi1",
          "value": "{to_loc}"
        },
        {
          "pointer/set": "/owe/{person}",
          "value": {
            "type": "math/add",
            "a": 1.5,
            "b": {
              "type": "math/mul",
              "a": 0.5,
              "b": 8
            }
          }
        }
      ]
    },
    "a_pay_driver": {
      "description": "Pay accumulated fare and exit taxi at destination. Requires sufficient cash.",
      "duration": "PT1M",
      "params": [
        "person",
        "to_loc"
      ],
      "bind": [
        {
          "name": "owed",
          "pointer": "/owe/{person}"
        }
      ],
      "body": [
        {
          "eval": {
            "type": "math/ge",
            "a": {
              "type": "pointer/get",
              "pointer": "/cash/{person}"
            },
            "b": "{owed}"
          }
        },
        {
          "pointer/set": "/cash/{person}",
          "value": {
            "type": "math/sub",
            "a": {
              "type": "pointer/get",
              "pointer": "/cash/{person}"
            },
            "b": "{owed}"
          }
        },
        {
          "pointer/set": "/owe/{person}",
          "value": 0.0
        },
        {
          "pointer/set": "/loc/{person}",
          "value": "{to_loc}"
        }
      ]
    }
  },
  "methods": {
    "travel": {
      "description": "Move a person to dest. Three alternatives: already there (no-op), walk, or taxi. Planner tries in order and backtracks on failure.",
      "params": [
        "person",
        "dest"
      ],
      "alternatives": [
        {
          "name": "already_there",
          "check": [
            {
              "eval": {
                "type": "math/eq",
                "a": {
                  "type": "pointer/get",
                  "pointer": "/loc/{person}"
                },
                "b": "{dest}"
              }
            }
          ],
          "subtasks": []
        },
        {
          "name": "by_foot",
          "subtasks": [
            [
              "a_walk",
              "{person}",
              "{dest}"
            ]
          ]
        },
        {
          "name": "by_taxi",
          "subtasks": [
            [
              "a_call_taxi",
              "{person}"
            ],
            [
              "a_ride_taxi",
              "{person}",
              "{dest}"
            ],
            [
              "a_pay_driver",
              "{person}",
              "{dest}"
            ]
          ]
        }
      ]
    },
    "loc": {
      "description": "Goal method: travel person to desired location.",
      "params": [
        "person",
        "dest"
      ],
      "alternatives": [
        {
          "name": "travel_to_dest",
          "subtasks": [
            [
              "travel",
              "{person}",
              "{dest}"
            ]
          ]
        }
      ]
    }
  },
  "todo_list": [
    [
      "travel",
      "alice",
      2
    ]
  ]
}
