{
  "@context": {
    "khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/",
    "domain": "khr:planning/domain/"
  },
  "@type": "domain:Definition",
  "name": "simple_travel",
  "enums": {
    "location": {
      "home_a": 0,
      "home_b": 1,
      "park": 2,
      "station": 3,
      "downtown": 4
    }
  },
  "variables": [
    {
      "name": "loc",
      "type": "int",
      "init": {
        "alice": 0,
        "bob": 1,
        "taxi1": 2,
        "taxi2": 3
      }
    },
    {
      "name": "cash",
      "type": "float",
      "init": {
        "alice": 20.0,
        "bob": 15.0
      }
    },
    {
      "name": "owe",
      "type": "float",
      "init": {
        "alice": 0.0,
        "bob": 0.0
      }
    }
  ],
  "actions": {
    "a_walk": {
      "params": [
        "person",
        "to_loc"
      ],
      "body": [
        {
          "pointer/set": "/loc/{person}",
          "value": "{to_loc}"
        }
      ]
    },
    "a_call_taxi": {
      "params": [
        "person"
      ],
      "bind": [
        {
          "name": "here",
          "pointer": "/loc/{person}"
        }
      ],
      "body": [
        {
          "pointer/set": "/loc/taxi1",
          "value": "{here}"
        },
        {
          "pointer/set": "/loc/{person}",
          "value": -1
        }
      ]
    },
    "a_ride_taxi": {
      "params": [
        "person",
        "to_loc"
      ],
      "body": [
        {
          "eval": {
            "type": "math/eq",
            "a": {
              "type": "pointer/get",
              "pointer": "/loc/{person}"
            },
            "b": -1
          }
        },
        {
          "pointer/set": "/loc/taxi1",
          "value": "{to_loc}"
        },
        {
          "pointer/set": "/owe/{person}",
          "value": {
            "type": "math/add",
            "a": 1.5,
            "b": {
              "type": "math/mul",
              "a": 0.5,
              "b": 8
            }
          }
        }
      ]
    },
    "a_pay_driver": {
      "params": [
        "person",
        "to_loc"
      ],
      "bind": [
        {
          "name": "owed",
          "pointer": "/owe/{person}"
        }
      ],
      "body": [
        {
          "eval": {
            "type": "math/ge",
            "a": {
              "type": "pointer/get",
              "pointer": "/cash/{person}"
            },
            "b": "{owed}"
          }
        },
        {
          "pointer/set": "/cash/{person}",
          "value": {
            "type": "math/sub",
            "a": {
              "type": "pointer/get",
              "pointer": "/cash/{person}"
            },
            "b": "{owed}"
          }
        },
        {
          "pointer/set": "/owe/{person}",
          "value": 0.0
        },
        {
          "pointer/set": "/loc/{person}",
          "value": "{to_loc}"
        }
      ]
    }
  },
  "methods": {
    "travel": {
      "params": [
        "person",
        "dest"
      ],
      "alternatives": [
        {
          "name": "already_there",
          "check": [
            {
              "eval": {
                "type": "math/eq",
                "a": {
                  "type": "pointer/get",
                  "pointer": "/loc/{person}"
                },
                "b": "{dest}"
              }
            }
          ],
          "subtasks": []
        },
        {
          "name": "by_foot",
          "subtasks": [
            [
              "a_walk",
              "{person}",
              "{dest}"
            ]
          ]
        },
        {
          "name": "by_taxi",
          "subtasks": [
            [
              "a_call_taxi",
              "{person}"
            ],
            [
              "a_ride_taxi",
              "{person}",
              "{dest}"
            ],
            [
              "a_pay_driver",
              "{person}",
              "{dest}"
            ]
          ]
        }
      ]
    }
  },
  "todo_list": [
    [
      "travel",
      "alice",
      2
    ]
  ]
}
