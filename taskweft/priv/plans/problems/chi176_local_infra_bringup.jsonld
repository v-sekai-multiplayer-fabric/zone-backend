              "eval": {
                "type": "math/eq",
                "a": {
                  "type": "pointer/get",
                  "pointer": "/stack_ready/idtx_flow"
                },
                "b": 1
              }
            },
            {
              "eval": {
                "type": "math/eq",
                "a": {
                  "type": "pointer/get",
                  "pointer": "/stack_ready/crdb"
                },
                "b": 1
              }
            },
            {
              "eval": {
                "type": "math/eq",
                "a": {
                  "type": "pointer/get",
                  "pointer": "/stack_ready/baker"
                },
                "b": 1
              }
            },
            {
              "eval": {
                "type": "math/eq",
                "a": {
                  "type": "pointer/get",
                  "pointer": "/stack_ready/uro"
                },
                "b": 1
              }
            },
            {
              "eval": {
                "type": "math/eq",
                "a": {
                  "type": "pointer/get",
                  "pointer": "/stack_ready/zone_a"
                },
