              "eval": {
                "type": "math/eq",
                "a": {
                  "type": "pointer/get",
                  "pointer": "/phase/baker"
                },
                "b": 3
              }
            }
          ],
          "subtasks": []
        },
        {
          "name": "direct",
          "subtasks": [
            [
              "complete_idtx_flow"
            ],
            [
              "complete_item",
              "baker"
            ],
            [
