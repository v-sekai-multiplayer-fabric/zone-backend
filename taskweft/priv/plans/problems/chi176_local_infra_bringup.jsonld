{
  "@context": {
    "khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/",
    "domain": "khr:planning/domain/"
  },
  "@type": "domain:Problem",
  "name": "chi176_local_infra_bringup",
  "source": "service_bringup",
  "description": "Fresh local-dev bring-up of the V-Sekai infra for Linear CHI-176 (Finish V-Sekai project Part 1). Seven items (idtx_flow, crdb, baker, uro, zone_a, zone_b, obs) on a single workstation via launchd plists + native binaries (no Docker, no Kubernetes). The problem supplies: the item set, per-service descriptions, per-service dependency wrapper methods (complete_uro depends on complete_crdb and complete_baker, etc.), the win condition, and the top-level tasks. The domain (service_bringup) supplies only the abstract phase walk + verification primitives.",
  "variables": [
    {
      "name": "phase",
      "type": "int",
      "init": {
        "idtx_flow": 0,
        "crdb": 0,
        "baker": 0,
        "uro": 0,
        "zone_a": 0,
        "zone_b": 0,
        "obs": 0
      }
    },
    {
      "name": "stack_ready",
      "type": "int",
      "init": {
        "idtx_flow": 0,
        "crdb": 0,
        "baker": 0,
        "uro": 0,
        "zone_a": 0,
        "zone_b": 0,
        "obs": 0
      }
    },
    {
      "name": "pass_condition",
      "type": "int",
      "init": {
        "idtx_flow_roundtrip_ok": 0,
        "crdb_sql_ok": 0,
        "baker_inbox_ok": 0,
        "uro_http_ok": 0,
        "zone_a_udp_ok": 0,
        "zone_b_udp_ok": 0,
        "obs_otlp_ok": 0
      }
    }
  ],
  "methods": {
    "complete_idtx_flow": {
      "alternatives": [
        {
          "name": "done",
          "check": [
            {
              "eval": {
                "type": "math/eq",
                "a": {
                  "type": "pointer/get",
                  "pointer": "/phase/idtx_flow"
                },
                "b": 3
              }
            }
          ],
          "subtasks": []
        },
        {
          "name": "direct",
          "subtasks": [
            [
              "complete_item",
              "idtx_flow"
            ],
            [
              "a_set_stack_ready",
              "idtx_flow",
              "ifire"
            ],
            [
              "a_verify_pass",
              "idtx_flow_roundtrip_ok",
              "ifire"
            ]
          ]
        }
      ]
    },
    "complete_crdb": {
      "alternatives": [
        {
          "name": "done",
          "check": [
            {
              "eval": {
                "type": "math/eq",
                "a": {
                  "type": "pointer/get",
                  "pointer": "/phase/crdb"
                },
                "b": 3
              }
            }
          ],
          "subtasks": []
