            },
            {
              "eval": {
                "type": "math/eq",
                "a": {
                  "type": "pointer/get",
                  "pointer": "/pass_condition/idtx_flow_roundtrip_ok"
                },
                "b": 1
              }
            },
            {
              "eval": {
                "type": "math/eq",
                "a": {
                  "type": "pointer/get",
                  "pointer": "/pass_condition/crdb_sql_ok"
                },
                "b": 1
              }
            },
            {
              "eval": {
                "type": "math/eq",
                "a": {
                  "type": "pointer/get",
                  "pointer": "/pass_condition/baker_inbox_ok"
                },
                "b": 1
