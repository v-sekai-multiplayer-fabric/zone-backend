{
  "@context": {
    "khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/",
    "domain": "khr:planning/domain/"
  },
  "@type": "domain:Problem",
  "name": "work_queue",
  "source": "service_bringup",
  "version": "4.3",
  "description": "multiplayer-fabric work queue (migrated to use the generic service_bringup domain). Actions are deterministic. Commands (actions sent to the real world) are probabilistic — MCExecutor models failure with a per-run failure_rate. Method alternatives encode genuinely different approaches for complex items, not duration variants. Single entity (ifire), one Saturday per a_* step.",
  "variables": [
    {
      "name": "phase",
      "type": "int",
      "init": {
        "lean4_infra": 3,
        "zone_arch": 3,
        "monorepo_split": 3,
        "taskweft": 3,
        "operator_camera": 3,
        "reduce_merge": 3,
        "rebac_enforcement": 3,
        "domain_jsonld": 3,
        "sqlite_journal": 3,
        "zone_registry": 3,
        "build_cache": 3,
        "operator_overlay": 3,
        "asset_delivery": 3,
        "baker_lifecycle": 3,
        "rectgtn_behavior": 3,
        "zone_border_handoff": 3,
        "taskweft_lean_proofs": 3,
        "taskweft_perf": 3,
        "openxr_simulator": 3,
        "isolated_submodule": 0,
        "vr_import_cache": 3,
        "vr_lasso_test": 3,
        "vr_lasso_s2h": 3,
        "vr_lasso_poi_reg": 3,
        "vr_lasso_query_pass": 0,
        "vr_call_gui_routing": 0,
        "vr_btn_pressed": 0,
        "vr_slider_value": 0,
        "zone_manifest": 0,
        "concert_archetype": 0,
        "ragdoll_archetype": 0,
        "pcvr_player": 0,
        "sandbox_rebac": 0,
        "artifactsmmog_bot": 0,
        "convoy_chokepoint": 0,
        "jellyfish_demo": 0,
        "headless_observer": 0,
        "headless_matrix": 0,
        "otel_tracing": 0,
        "godot_otel_module": 3,
        "turboquant_llm": 0,
        "gepa_cycle": 0
      }
    },
    {
      "name": "approach",
      "type": "int",
      "init": {
        "vr_lasso_test": 0,
        "sandbox_rebac": 0,
        "turboquant_llm": 0,
        "convoy_chokepoint": 0,
        "gepa_cycle": 0
      }
    },
    {
      "name": "pass_condition",
      "type": "int",
      "init": {
        "engine_boot": 0,
        "vrm_visible": 0,
        "character_steps": 0,
        "zone_connect": 0,
        "all_mires": 0,
        "entity_slots": 0,
        "tick_rate": 0,
        "clean_shutdown": 0,
        "lasso_query_returns_poi": 0,
        "call_gui_input_fires": 0,
        "btn_pressed_fires": 0,
        "virtual_input_fires": 0,
        "slider_value_changes": 0
      }
    },
    {
      "name": "scenario",
      "type": "int",
      "init": {
        "concert": 0,
        "chokepoint": 0,
        "convoy": 0,
        "ragdoll": 0
      }
    },
    {
      "name": "stack_ready",
      "type": "int",
      "init": {
        "engine_assembly": 1,
        "godot_fork": 1,
        "build_system": 0,
        "zone_server": 0,
        "zone_registry": 1,
        "interest_management": 1,
        "bots": 1,
        "observer": 0
      }
    }
  ],
  "methods": {
    "xr_dev_track": {
