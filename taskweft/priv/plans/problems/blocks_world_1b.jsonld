{
  "@context": {
    "khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/",
    "domain": "khr:planning/domain/"
  },
  "@type": "domain:Problem",
  "name": "blocks_world_1b",
  "source": "blocks_world",
  "description": "IPyHOP blocks_world problem 1b: 3 blocks, multigoal c on b on a. mgm_move_blocks expressed as flow/for scan over clear variable.",
  "variables": [
    {
      "name": "pos",
      "type": "ref",
      "init": {
        "a": "b",
        "b": "table",
        "c": "table"
      }
    },
    {
      "name": "clear",
      "type": "bool",
      "init": {
        "c": true,
        "b": false,
        "a": true
      }
    },
    {
      "name": "holding",
      "type": "bool",
      "init": {
        "hand": false
      }
    },
    {
      "name": "goal_pos",
      "type": "ref",
      "init": {
        "a": "table",
        "b": "a",
        "c": "b"
      }
    }
  ],
  "methods": {
    "move_blocks": {
      "params": [],
      "name": "move_blocks",
      "scan": {
        "over": "clear",
        "recurse": "move_blocks",
        "branches": [
          {
            "name": "move_to_block",
            "bind": [
              {
                "name": "gk",
                "pointer": "/goal_pos/{_key}"
              },
              {
                "name": "ggk",
                "pointer": "/goal_pos/{gk}"
              }
            ],
            "check": [
              {
                "pointer": "/clear/{_key}",
                "eq": true
              },
              {
                "pointer": "/pos/{_key}",
                "neq": "{gk}"
              },
              {
                "pointer": "/goal_pos/{_key}",
                "neq": "table"
              },
              {
                "pointer": "/pos/{gk}",
                "eq": "{ggk}"
              },
              {
                "pointer": "/clear/{gk}",
                "eq": true
              }
            ],
            "subtasks": [
              [
                "move_one",
                "{_key}",
                "{gk}"
              ]
            ]
          },
          {
            "name": "move_to_table",
            "check": [
              {
                "pointer": "/clear/{_key}",
                "eq": true
              },
              {
                "pointer": "/goal_pos/{_key}",
                "eq": "table"
              },
              {
                "pointer": "/pos/{_key}",
                "neq": "table"
              }
            ],
            "subtasks": [
              [
                "move_one",
                "{_key}",
                "table"
              ]
            ]
          },
          {
            "name": "waiting",
            "bind": [
              {
                "name": "gk",
                "pointer": "/goal_pos/{_key}"
              }
            ],
            "check": [
              {
                "pointer": "/clear/{_key}",
                "eq": true
              },
              {
                "pointer": "/pos/{_key}",
                "neq": "{gk}"
              }
            ],
            "subtasks": [
              [
                "move_one",
                "{_key}",
                "table"
              ]
            ]
          }
        ],
        "done": [],
        "done_subtasks": []
      }
    }
  },
  "todo_list": [
    [
      "move_blocks"
    ]
  ]
}
