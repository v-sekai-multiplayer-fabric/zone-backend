{
  "@context": {
    "khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/",
    "domain": "khr:planning/domain/"
  },
  "@type": "domain:Problem",
  "name": "job_shop_one",
  "source": "job_shop_scheduling",
  "description": "IPyHOP job_shop problem 1: schedule job1 only (2 tasks, 2 machines).",
  "variables": [
    {
      "name": "task_status",
      "type": "int",
      "init": {
        "job1_taskA": 0,
        "job1_taskB": 0,
        "job2_taskC": 0,
        "job2_taskD": 0
      }
    },
    {
      "name": "machine_avail",
      "type": "int",
      "init": {
        "machine1": 1,
        "machine2": 1
      }
    }
  ],
  "todo_list": [
    [
      "schedule_task",
      "job1_taskA",
      "machine1"
    ],
    [
      "schedule_task",
      "job1_taskB",
      "machine2"
    ]
  ]
}
