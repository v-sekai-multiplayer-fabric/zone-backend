/-- Float → string in the shape Python's `repr(float)` would print, so the JSON round-trip is byte-identical. -/
def fmtFloat (x : Float) : String := toString x

def vec3ToJson (v : Vec3) : String :=
  "[" ++ fmtFloat v.1 ++ ", " ++ fmtFloat v.2.1 ++ ", " ++ fmtFloat v.2.2 ++ "]"

def quatToJson (q : Quat) : String :=
  "[" ++ fmtFloat q.x ++ ", " ++ fmtFloat q.y ++ ", "
       ++ fmtFloat q.z ++ ", " ++ fmtFloat q.w ++ "]"

def constraintToJson (c : Constraint) : String :=
  "{\"position\": " ++ vec3ToJson c.position
    ++ ", \"isAtExistingNode\": " ++ (if c.isAtExistingNode then "true" else "false")
    ++ ", \"isAtNewEndpoint\": " ++ (if c.isAtNewEndpoint then "true" else "false")
    ++ ", \"isIntersection\": " ++ (if c.isIntersection then "true" else "false")
    ++ ", \"alignTangents\": " ++ (if c.alignTangents then "true" else "false") ++ "}"

def arrToJson [Inhabited α] (f : α → String) (xs : Array α) : String := Id.run do
  let mut s := "["
  for i in [:xs.size] do
    if i > 0 then s := s ++ ", "
    s := s ++ f xs[i]!
  return s ++ "]"

def strokeToJson (s : Stroke) : String :=
  "{\"id\": " ++ toString s.id
    ++ ", \"ctrlPts\": " ++ arrToJson vec3ToJson s.ctrlPts
    ++ ", \"inputSamples\": " ++ arrToJson vec3ToJson s.inputSamples
    ++ ", \"appliedConstraints\": " ++ arrToJson constraintToJson s.appliedConstraints
    ++ ", \"rejectedConstraints\": " ++ arrToJson constraintToJson s.rejectedConstraints
    ++ ", \"onSurface\": " ++ (if s.onSurface then "true" else "false")
    ++ ", \"planar\": " ++ (if s.planar then "true" else "false")
    ++ ", \"closedLoop\": " ++ (if s.closedLoop then "true" else "false") ++ "}"

def patchToJson (p : Patch) : String :=
  "{\"id\": " ++ toString p.id
    ++ ", \"foundByAlgo\": " ++ (if p.foundByAlgo then "true" else "false")
    ++ ", \"strokesID\": " ++ arrToJson toString p.strokesID ++ "}"

def eventToJson (e : SketchEvent) : String :=
  "{\"time\": " ++ fmtFloat e.time
    ++ ", \"interactionType\": " ++ toString e.interactionType
    ++ ", \"elementID\": " ++ toString e.elementID
    ++ ", \"mirroring\": " ++ (if e.mirroring then "true" else "false")
    ++ ", \"headPos\": " ++ vec3ToJson e.headPos
    ++ ", \"headRot\": " ++ quatToJson e.headRot
    ++ ", \"canvasPos\": " ++ vec3ToJson e.canvasPos
    ++ ", \"canvasRot\": " ++ quatToJson e.canvasRot
    ++ ", \"canvasScale\": " ++ fmtFloat e.canvasScale
    ++ ", \"primaryHandPos\": " ++ vec3ToJson e.primaryHandPos ++ "}"

def toJson : String :=
  "{\"sketchSystem\": " ++ toString sketchSystem
    ++ ", \"sketchModel\": " ++ toString sketchModel
    ++ ", \"interactionMode\": " ++ toString interactionMode
    ++ ", \"allSketchedStrokes\": " ++ arrToJson strokeToJson allSketchedStrokes
    ++ ", \"allCreatedPatches\": " ++ arrToJson patchToJson allCreatedPatches
    ++ ", \"systemStates\": " ++ arrToJson eventToJson systemStates ++ "}"

end CassieAvbd.CycleDetect.HatRawData
